# ===========================================
# CONFIGURACIÓN DE APLICACIÓN
# ===========================================

# Entorno de ejecución (development, production, testing)
FLASK_ENV=development

# Clave secreta para sesiones (cambiar en producción)
SECRET_KEY=dev-secret-key-change-in-production

# Usuario por defecto para auditoria
AUDIT_USER=ui_user

# ===========================================
# CONFIGURACIÓN DE BASE DE DATOS
# ===========================================

# Tipo de base de datos (sqlite, postgresql, mysql)
DB_TYPE=sqlite

# Conexión SQLite (ruta relativa o absoluta)
DB_NAME=dataset_importadora_electrodomesticos_4000.db

# Conexión PostgreSQL (descomentar para usar PostgreSQL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=crud_pickings
# DB_USER=postgres
# DB_PASSWORD=your-password-here

# ===========================================
# CONFIGURACIÓN DE ARCHIVOS
# ===========================================

# Nombre del archivo CSV principal
CSV_FILE=dataset_importadora_electrodomesticos_4000.csv

# Directorio para backups
BACKUP_DIR=backups

# ===========================================
# CONFIGURACIÓN DEL SERVIDOR
# ===========================================

# Puerto para Flask
FLASK_PORT=8050

# Puerto para Dashboard
DASH_PORT=8051

# Habilitar debug en desarrollo
DEBUG=True

# ===========================================
# CONFIGURACIÓN DE PRODUCCIÓN
# ===========================================

# Número de workers (gunicorn)
WORKERS=4

# Timeout en segundos
TIMEOUT=120
